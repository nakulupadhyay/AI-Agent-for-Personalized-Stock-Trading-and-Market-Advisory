   "source": [
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "\n",
    "def fetch_data(tickers, start=\"2015-01-01\", end=\"2024-01-01\"):\n",
    "    data = {}\n",
    "    for ticker in tickers:\n",
    "        df = yf.download(ticker, start=start, end=end)\n",
    "        df.dropna(inplace=True)\n",
    "        data[ticker] = df\n",
    "    return data"
   ]
